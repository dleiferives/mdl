// Test struct usage
namespace structs;

struct Point {
    x: Int,
    y: Int,
    z: Int
}

struct Player {
    name: String,
    health: Int,
    pos: Point
}

fn create_point() : Point {
    data p := Point{x: 10, y: 64, z: -100};
    return p;
}

fn access_field() : Int {
    data p := Point{x: 5, y: 10, z: 15};
    data sum := p.x + p.y + p.z;
    return sum;
}

fn nested_struct() : Int {
    data player := Player{
        name: "Steve",
        health: 20,
        pos: Point{x: 0, y: 64, z: 0}
    };
    return player.pos.y;
}
